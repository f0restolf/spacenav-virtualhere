#!/bin/bash
# spacemouse-ctl - Switch SpaceMouse between local (Onshape) and forward (Windows VM)
#
# Usage:
#   spacemouse-ctl local     - Use SpaceMouse locally with spacenav-ws
#   spacemouse-ctl forward   - Forward SpaceMouse via sandboxed VirtualHere
#   spacemouse-ctl status    - Show current mode
#   spacemouse-ctl stop      - Stop everything, return to spacenavd

set -euo pipefail

BUSID="1-1"
VENDOR="256f"
PRODUCT="c635"
SPACENAV_WS_DIR="$HOME/Projects/software/spacenav/spacenav-ws"
STATEFILE="/tmp/spacemouse-mode"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[✓]${NC} $1"; }
log_warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
log_error() { echo -e "${RED}[✗]${NC} $1"; }

get_status() {
    if systemctl is-active --quiet virtualhere-spacemouse; then
        echo "forward"
    elif pgrep -f "spacenav-ws serve" > /dev/null 2>&1; then
        echo "local"
    else
        echo "idle"
    fi
}

stop_local() {
    if pgrep -f "spacenav-ws serve" > /dev/null 2>&1; then
        log_info "Stopping spacenav-ws..."
        pkill -9 -f "spacenav-ws" || true
        sleep 1
    fi
}

stop_forward() {
    if systemctl is-active --quiet virtualhere-spacemouse; then
        log_info "Stopping VirtualHere service..."
        pkexec /usr/local/bin/spacemouse-ctl-root stop-vh
        sleep 1
    fi
}

start_local() {
    stop_forward
    
    # Make sure spacenavd is running
    if ! systemctl is-active --quiet spacenavd; then
        log_info "Starting spacenavd..."
        pkexec /usr/local/bin/spacemouse-ctl-root start-spnav
        sleep 1
    fi
    
    # Retrigger udev to restore normal permissions
    pkexec /usr/local/bin/spacemouse-ctl-root udev-trigger
    
    # Start spacenav-ws in background
    log_info "Starting spacenav-ws..."
    cd "$SPACENAV_WS_DIR"
    nohup uv run --python 3.12 spacenav-ws serve > /tmp/spacenav-ws.log 2>&1 &
    
    echo "local" > "$STATEFILE"
    sleep 5
    
    if pgrep -f "spacenav-ws serve" > /dev/null 2>&1; then
        log_info "SpaceMouse ready for local use (Onshape)"
        log_info "WebSocket server: https://127.51.68.120:8181"
    else
        log_error "Failed to start spacenav-ws. Check /tmp/spacenav-ws.log"
        return 1
    fi
}

start_forward() {
    stop_local
    
    # Stop spacenavd so it releases the device
    if systemctl is-active --quiet spacenavd; then
        log_info "Stopping spacenavd to release device..."
        pkexec /usr/local/bin/spacemouse-ctl-root stop-spnav
        sleep 1
    fi
    
    # Retrigger udev - the sandboxed service runs as virtualhere user
    # which has access via DeviceAllow in the service file
    pkexec /usr/local/bin/spacemouse-ctl-root udev-trigger
    
    # Start sandboxed VirtualHere service
    log_info "Starting sandboxed VirtualHere service..."
    pkexec /usr/local/bin/spacemouse-ctl-root start-vh
    
    echo "forward" > "$STATEFILE"
    sleep 2
    
    if systemctl is-active --quiet virtualhere-spacemouse; then
        log_info "SpaceMouse forwarding via VirtualHere (sandboxed)"
        log_info "Reverse SSL connection to Windows VM"
        log_info "Check connection: sudo journalctl -u virtualhere-spacemouse -f"
    else
        log_error "Failed to start VirtualHere. Check: sudo journalctl -u virtualhere-spacemouse"
        return 1
    fi
}

do_stop() {
    stop_local
    stop_forward
    
    # Restart spacenavd for native apps
    if ! systemctl is-active --quiet spacenavd; then
        log_info "Restarting spacenavd..."
        pkexec /usr/local/bin/spacemouse-ctl-root start-spnav
    fi
    
    # Restore normal udev permissions
    pkexec /usr/local/bin/spacemouse-ctl-root udev-trigger
    
    echo "idle" > "$STATEFILE"
    log_info "SpaceMouse stopped (spacenavd running for native apps)"
}

show_status() {
    local mode=$(get_status)
    
    case "$mode" in
        local)
            log_info "Mode: LOCAL (spacenav-ws for Onshape)"
            echo "      WebSocket: https://127.51.68.120:8181"
            ;;
        forward)
            log_info "Mode: FORWARD (VirtualHere → Windows VM)"
            echo "      Service: virtualhere-spacemouse.service (sandboxed)"
            echo "      Logs: sudo journalctl -u virtualhere-spacemouse -f"
            ;;
        idle)
            log_warn "Mode: IDLE (spacenavd only, for native apps)"
            ;;
        *)
            log_error "Mode: UNKNOWN"
            ;;
    esac
}

show_security() {
    echo ""
    echo "Security Status:"
    echo "────────────────"
    
    if systemctl is-active --quiet virtualhere-spacemouse; then
        echo "VirtualHere running as: $(ps -o user= -p $(pgrep -f vhusbdx86_64) 2>/dev/null || echo 'unknown')"
        echo ""
        echo "Sandbox restrictions (from systemd):"
        systemctl show virtualhere-spacemouse --property=ProtectHome,ProtectSystem,DevicePolicy,NoNewPrivileges,CapabilityBoundingSet 2>/dev/null | sed 's/^/  /'
    else
        echo "VirtualHere not running"
    fi
}

show_help() {
    cat << EOF
SpaceMouse Control - Secure forwarding with sandboxed VirtualHere

Usage: $(basename "$0") <command>

Commands:
    local       Use SpaceMouse locally (spacenav-ws for Onshape)
    forward     Forward to Windows VM (sandboxed VirtualHere reverse SSL)
    stop        Stop all modes, return to spacenavd-only
    status      Show current mode
    security    Show sandbox security status
    help        Show this help

The 'forward' mode runs VirtualHere in a heavily sandboxed systemd service:
  • Runs as unprivileged 'virtualhere' user
  • Cannot access /home or write to system files
  • Can only access SpaceMouse USB device
  • Can only make outbound network connections (reverse client)
  • Strict syscall filtering and capability dropping

Examples:
    $(basename "$0") local      # Use with Onshape in browser
    $(basename "$0") forward    # Forward to Windows VM for CAD
    $(basename "$0") security   # Verify sandbox is working
EOF
}

# Main
case "${1:-status}" in
    local)
        start_local
        ;;
    forward)
        start_forward
        ;;
    stop)
        do_stop
        ;;
    status)
        show_status
        ;;
    security)
        show_security
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
